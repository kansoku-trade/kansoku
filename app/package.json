{
  "name": "trade-app",
  "private": true,
  "packageManager": "pnpm@11.10.0",
  "scripts": {
    "dev": "concurrently -n web,server -c blue,green \"pnpm --filter @trade/web dev\" \"pnpm --filter @trade/server dev\"",
    "dev:desktop": "concurrently --kill-others -n web,desktop -c blue,magenta \"pnpm --filter @trade/web dev\" \"pnpm --filter @trade/desktop dev\"",
    "start": "pnpm --filter @trade/server start",
    "start:desktop": "pnpm --filter @trade/web build && pnpm --filter @trade/desktop start",
    "build": "pnpm --filter @trade/web build",
    "build:desktop": "pnpm --filter @trade/desktop build",
    "package:desktop": "pnpm --filter @trade/desktop package",
    "release:desktop:dry-run": "desktop/scripts/release-dry-run.sh",
    "test": "pnpm -r test",
    "test:desktop": "pnpm --filter @trade/desktop test",
    "typecheck": "pnpm -r typecheck",
    "typecheck:desktop": "pnpm --filter @trade/desktop typecheck"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
