{
  "name": "trade-app",
  "private": true,
  "packageManager": "pnpm@11.10.0",
  "scripts": {
    "dev": "concurrently -n web,server -c blue,green \"pnpm --filter @trade/web dev\" \"pnpm --filter @trade/server dev\"",
    "start": "pnpm --filter @trade/server start",
    "build": "pnpm --filter @trade/web build",
    "package:desktop": "pnpm --filter @trade/desktop package",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
