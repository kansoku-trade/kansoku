{
  "name": "kansoku",
  "private": true,
  "packageManager": "pnpm@11.10.0",
  "scripts": {
    "dev": "concurrently -n web,server -c blue,green \"pnpm --filter @kansoku/web dev\" \"pnpm --filter @kansoku/server dev\"",
    "dev:unlocked": "KANSOKU_LICENSE_BYPASS=1 pnpm dev",
    "dev:desktop": "concurrently --kill-others -n web,desktop -c blue,magenta \"pnpm --filter @kansoku/web dev\" \"pnpm --filter @kansoku/desktop dev\"",
    "dev:desktop:unlocked": "KANSOKU_LICENSE_BYPASS=1 pnpm dev:desktop",
    "start": "pnpm --filter @kansoku/server start",
    "start:desktop": "pnpm --filter @kansoku/web build && pnpm --filter @kansoku/desktop start",
    "build": "pnpm --filter @kansoku/web build",
    "build:desktop": "pnpm --filter @kansoku/desktop build",
    "package:desktop": "pnpm --filter @kansoku/desktop package",
    "bench": "pnpm --filter @kansoku/bench exec vite-node src/cli.ts",
    "release:desktop:dry-run": "desktop/scripts/release-dry-run.sh",
    "test": "pnpm -r test",
    "test:desktop": "pnpm --filter @kansoku/desktop test",
    "typecheck": "pnpm -r typecheck",
    "typecheck:desktop": "pnpm --filter @kansoku/desktop typecheck",
    "credits": "node scripts/generate-credits.mjs"
  },
  "devDependencies": {
    "concurrently": "^10.0.3"
  },
  "license": "SEE LICENSE IN LICENSE"
}
