{
  "$id": "https://github.com/kansoku-trade/kansoku-bench-data/blob/main/manifests/schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "$schema": { "type": "string" },
    "schemaVersion": { "const": 1 },
    "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
    "label": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]{0,63}$" },
    "revision": { "type": "string", "pattern": "^r[1-9][0-9]*$" },
    "kind": { "enum": ["single-shot", "episode"] },
    "status": { "enum": ["pilot", "production"] },
    "modes": {
      "type": "array",
      "minItems": 1,
      "maxItems": 2,
      "uniqueItems": true,
      "items": { "enum": ["blind", "live"] }
    },
    "cohort": { "enum": ["live-2026", "blind-anonymous"] },
    "visibility": { "const": "private" },
    "repository": { "type": "string", "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$" },
    "release": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tag", "asset", "sha256", "sizeBytes", "archiveRoot"],
      "properties": {
        "tag": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$" },
        "asset": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*\\.tar\\.zst$" },
        "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "sizeBytes": { "type": "integer", "minimum": 1 },
        "archiveRoot": { "type": "string" }
      }
    },
    "banks": {
      "type": "object",
      "minProperties": 1,
      "propertyNames": { "pattern": "^[a-z0-9][a-z0-9-]*$" },
      "additionalProperties": { "type": "integer", "minimum": 1 }
    },
    "generator": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repository", "commit"],
      "properties": {
        "repository": { "type": "string", "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$" },
        "commit": { "type": "string", "pattern": "^[a-f0-9]{40}$" }
      }
    },
    "publishedAt": { "type": "string", "format": "date-time" }
  },
  "required": [
    "schemaVersion",
    "id",
    "revision",
    "kind",
    "visibility",
    "repository",
    "release",
    "banks",
    "generator",
    "publishedAt"
  ],
  "title": "Kansoku benchmark dataset manifest",
  "type": "object"
}
